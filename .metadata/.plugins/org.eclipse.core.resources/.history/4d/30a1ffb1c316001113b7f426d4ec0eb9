package com.lpu.demo.cache;

import org.springframework.beans.factory.annotation.Autowired;
import com.lpu.demo.entity.*;
import org.springframework.cache.annotation.Cacheable;


import com.lpu.demo.repository.StudentRepository;

public class StudentServiceCache {
	
	@Autowired
	private StudentRepository studentRepo;
	
	//Cache data when first fetched
	@Cacheable(value = "students", key = "#result.id")
	public Student getStudentById(int id) {
		System.err.println("Fetching from DB....."); // just to check cache working
		return studentRepo.findById(id).orElseThrow(()-> new ResourceNotFoundException("Student not found");
	}
	
	
	
	

}
